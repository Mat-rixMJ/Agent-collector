# --- Data collection ---
APIFY_TOKEN=your_apify_token_here

# --- LLM provider (pick one) ---
LLM_PROVIDER=ollama              # openrouter | nvidia | ollama
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
NVIDIA_API_KEY=your_nvidia_build_key_here
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
OLLAMA_MODEL=qwen2.5:7b

# --- Telegram gateway ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Paths ---
OBSIDIAN_VAULT_PATH=./obsidian_vault
KANBAN_BOARD_PATH=./kanban/board.json

# --- Target ---
TARGET_SITE=crowdwisdomtrading.com
NICHE=retail trading, prop firm challenges, market commentary
