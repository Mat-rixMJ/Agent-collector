# --- Data collection ---
APIFY_TOKEN=your_apify_token_here

# --- LLM provider (pick one) ---
LLM_PROVIDER=ollama              # openrouter | nvidia | ollama
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b:free
NVIDIA_API_KEY=your_nvidia_key_here
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
OLLAMA_MODEL=qwen2.5:7b

# --- Telegram gateway (optional) ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Paths ---
OBSIDIAN_VAULT_PATH=./obsidian_vault
KANBAN_BOARD_PATH=./kanban/board.json

# --- Target (CONFIGURE THIS FOR YOUR COMPANY/NICHE) ---
TARGET_SITE=yourcompany.com
NICHE=your industry, your market, your keywords
PRODUCT_DESCRIPTION=Brief description of what your company does and its key differentiators
